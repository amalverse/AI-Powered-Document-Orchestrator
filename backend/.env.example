# ============================================================
# AI-Powered Document Orchestrator — Backend Environment Variables
# ============================================================
# Copy this file to .env and fill in your actual values.
# NEVER commit your real .env file to version control.


# GROQ Llama AI API Key 
GROQ_API_KEY=your_groq_api_key_here

# n8n Webhook URL (Production)
# Your active n8n cloud webhook endpoint
N8N_WEBHOOK_URL=https://your-n8n-instance.app.n8n.cloud/webhook/document-orchestrator

# Server Port (default: 5000)
PORT=5000
