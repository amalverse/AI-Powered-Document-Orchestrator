      "webhookId": "document-orchestrator"
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.groq.com/openai/v1/chat/completions",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Content-Type",
              "value": "application/json"
            },
            {
              "name": "Authorization",
              "value": "Bearer YOUR_GROQ_API_KEY"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({\n  model: \"llama-3.3-70b-versatile\",\n  messages: [{\n    role: \"user\",\n    content: \"Analyze this document text based on the query:\\n\\nQuery: \" + $json.body.query + \"\\n\\nDocument Text: \" + ($json.body.text || '').substring(0, 20000) + \"\\n\\nYou MUST reply with ONLY a raw JSON object with no markdown formatting. The JSON must have exactly two keys: \\\"answer\\\" (a detailed string analysis answering the query) and \\\"email_body\\\" (well-formatted HTML content for the email alert body).\"\n  }],\n  response_format: {\"type\": \"json_object\"},\n  temperature: 0.3\n}) }}",
        "bodyParameters": {
          "parameters": []
        },
        "options": {}
      },
      "id": "example-groq-id",
      "name": "Groq AI - Answer & Email",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [
        -1264,
        -432
      ]
    },
    {
      "parameters": {
        "conditions": {
          "string": [
            {
              "value1": "={{$node[\"Webhook\"].json.body.email}}",
              "operation": "isNotEmpty"
            }
          ]
        }
      },
      "id": "example-if-id",
      "name": "IF Email Exists",
      "type": "n8n-nodes-base.if",
      "typeVersion": 1,
      "position": [
        -1024,
        -432
      ]
    },
    {
      "parameters": {
        "sendTo": "={{$node[\"Webhook\"].json.body.email}}",
        "subject": "Automation Alert: Document Analysed",
        "message": "={{JSON.parse($node[\"Groq AI - Answer & Email\"].json.choices[0].message.content).email_body}}",
        "options": {
          "senderName": "AI-Powered Document Orchestrator"
        }
      },
      "id": "example-gmail-id",
      "name": "Send Gmail Address",
      "type": "n8n-nodes-base.gmail",
      "typeVersion": 2.1,
      "position": [
        -768,
        -560
      ]
    },
    {
      "parameters": {
        "respondWith": "json",
        "responseBody": "={{\n  JSON.stringify({\n    answer: JSON.parse($node['Groq AI - Answer & Email'].json.choices[0].message.content).answer,\n    email_body: JSON.parse($node['Groq AI - Answer & Email'].json.choices[0].message.content).email_body,\n    status: \"Email Sent Successfully\"\n  })\n}}",
        "options": {}
      },
      "id": "example-respond-sent-id",
