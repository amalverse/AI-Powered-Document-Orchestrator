{
  "name": "AI Document Orchestrator Example",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "document-orchestrator",
        "responseMode": "responseNode",
        "options": {}
      },
      "id": "example-webhook-id",
      "name": "Webhook",
      "type": "n8n-nodes-base.webhook",
