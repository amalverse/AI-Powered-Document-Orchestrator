# ============================================================
# Frontend Environment Variables
# ============================================================
# Copy this file and rename it to .env
# Update the values below for your environment
# IMPORTANT: Never commit your .env file to Git!
# NOTE: In Vite, all env variables MUST start with VITE_

# Your backend API server URL
# During development: http://localhost:5000
# In production: https://your-backend-app.onrender.com (or wherever you hosted it)
VITE_API_BASE_URL=http://localhost:5000
